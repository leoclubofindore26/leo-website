t:320px;object-fit:cover;object-position:center 38%\">\n          <figcaption style=\"position:absolute;left:0;right:0;bottom:0;display:flex;justify-content:center;padding:16px\"><span style=\"background:#161412;color:#fff;font-weight:700;font-size:14px;padding:9px 20px;border-radius:30px;border:2px solid #fff\">{{ g.name }}<\u002Fspan><\u002Ffigcaption>\n        <\u002Ffigure>\n      <\u002Fsc-for>\n    <\u002Fdiv>\n    <span style=\"position:absolute;top:0;right:0;bottom:14px;width:56px;background:linear-gradient(90deg,rgba(251,249,244,0),#FBF9F4);pointer-events:none\"><\u002Fspan>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ===================== JOIN ===================== -->\n<section id=\"join\" data-screen-label=\"Join the club\" style=\"padding:120px 7vw 110px;position:relative\">\n  <span style=\"position:absolute;top:80px;right:9vw;animation:spin 14s linear infinite;opacity:.9\"><svg width=\"64\" height=\"64\" viewBox=\"0 0 24 24\" fill=\"#FF5A36\"><path d=\"M12 1c1 7 3 9 11 11-8 2-10 4-11 11-1-7-3-9-11-11 8-2 10-4 11-11Z\"><\u002Fpath><\u002Fsvg><\u002Fspan>\n  <div class=\"lci-2col\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;max-width:1100px;margin:0 auto\">\n    <div>\n      <p style=\"font-family:'Caveat';font-size:28px;color:#FF5A36;font-weight:700;transform:rotate(-2deg)\">come roar with us<\u002Fp>\n      <h2 style=\"font-family:'Bricolage Grotesque';font-weight:800;font-size:clamp(40px,6.5vw,84px);line-height:.95;letter-spacing:-.03em\">Ready to lead?<\u002Fh2>\n      <p style=\"font-size:19px;line-height:1.6;color:#3a3833;font-weight:500;margin-top:20px;max-width:46ch\">If you're young, curious and want to make Indore better — there's a seat for you. No experience needed, just energy.<\u002Fp>\n      <div style=\"margin-top:30px;display:flex;flex-direction:column;gap:14px\">\n        <div style=\"display:flex;align-items:center;gap:12px;font-size:16px;font-weight:600\"><span style=\"display:grid;place-items:center;width:38px;height:38px;border-radius:50%;background:#161412;color:#fff;flex:none\">☎<\u002Fspan> President · Aditya Raja Deshlahra — +91 85190 34349<\u002Fdiv>\n        <div style=\"display:flex;align-items:center;gap:12px;font-size:16px;font-weight:600\"><span style=\"display:grid;place-items:center;width:38px;height:38px;border-radius:50%;background:#161412;color:#fff;flex:none\">☎<\u002Fspan> Secretary · Hardik Goda — +91 94798 71889<\u002Fdiv>\n        <div style=\"display:flex;align-items:center;gap:12px;font-size:16px;font-weight:600\"><span style=\"display:grid;place-items:center;width:38px;height:38px;border-radius:50%;background:#161412;color:#fff;flex:none\">✉<\u002Fspan> leoclubofindore26@gmail.com<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <form onsubmit=\"{{ onSubmit }}\" style=\"background:#161412;border-radius:28px;padding:34px;box-shadow:8px 8px 0 #2F6BFF\">\n      <sc-if value=\"{{ submitted }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"display:grid;place-items:center;text-align:center;min-height:300px;color:#FBF9F4\">\n          <div>\n            <div style=\"font-size:56px\">🎉<\u002Fdiv>\n            <div style=\"font-family:'Bricolage Grotesque';font-weight:800;font-size:28px;margin-top:8px\">You're on the list!<\u002Fdiv>\n            <p style=\"color:#bfbcb4;margin-top:8px;font-weight:500\">We'll reach out soon. Welcome to the pride.<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ notSubmitted }}\" hint-placeholder-val=\"{{ true }}\">\n        <div>\n          <div style=\"font-family:'Bricolage Grotesque';font-weight:700;font-size:22px;color:#FBF9F4;margin-bottom:18px\">Apply in 30 seconds<\u002Fdiv>\n          <input placeholder=\"Full name\" style=\"width:100%;margin-bottom:12px;padding:14px 16px;border-radius:12px;border:2px solid #3a3833;background:#211f1c;color:#fff;font-size:15px;font-family:inherit;outline:none\">\n          <input placeholder=\"Phone / WhatsApp\" style=\"width:100%;margin-bottom:12px;padding:14px 16px;border-radius:12px;border:2px solid #3a3833;background:#211f1c;color:#fff;font-size:15px;font-family:inherit;outline:none\">\n          <input placeholder=\"Email\" style=\"width:100%;margin-bottom:12px;padding:14px 16px;border-radius:12px;border:2px solid #3a3833;background:#211f1c;color:#fff;font-size:15px;font-family:inherit;outline:none\">\n          <textarea placeholder=\"Why do you want to join? (optional)\" rows=\"3\" style=\"width:100%;margin-bottom:16px;padding:14px 16px;border-radius:12px;border:2px solid #3a3833;background:#211f1c;color:#fff;font-size:15px;font-family:inherit;outline:none;resize:none\"><\u002Ftextarea>\n          <button type=\"submit\" style=\"cursor:pointer;width:100%;background:#FF5A36;color:#fff;font-weight:700;font-size:17px;padding:15px;border-radius:44px;border:2px solid #FF5A36\">Send my application →<\u002Fbutton>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n    <\u002Fform>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ===================== FOOTER ===================== -->\n<footer style=\"background:#161412;color:#FBF9F4;padding:60px 7vw 40px;border-top:2px solid #161412\">\n  <div style=\"display:flex;justify-content:space-between;flex-wrap:wrap;gap:30px;align-items:flex-start\">\n    <div style=\"max-width:34ch\">\n      <div style=\"display:flex;align-items:center;gap:11px;margin-bottom:14px\">\n        <span style=\"display:grid;place-items:center;width:42px;height:42px;background:#FBF9F4;color:#161412;border-radius:50%;font-family:'Bricolage Grotesque';font-weight:800;font-size:20px;transform:rotate(-6deg)\">L<\u002Fspan>\n        <span style=\"font-family:'Bricolage Grotesque';font-weight:700;font-size:17px\">Leo Club of Indore<\u002Fspan>\n      <\u002Fdiv>\n      <p style=\"color:#9b988f;font-size:15px;line-height:1.55;font-weight:500\">Leadership · Experience · Opportunity. A youth wing of Lions Clubs International — Multiple 3233 G1. Serving Indore since 1972.<\u002Fp>\n    <\u002Fdiv>\n    <div style=\"display:flex;gap:54px;flex-wrap:wrap\">\n      <div style=\"display:flex;flex-direction:column;gap:10px\">\n        <span style=\"font-weight:700;color:#fff;margin-bottom:4px\">Explore<\u002Fspan>\n        <a href=\"#about\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">About LCI<\u002Fa>\n        <a href=\"#leoism\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">Leoism<\u002Fa>\n        <a href=\"#leaders\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">Leaders<\u002Fa>\n        <a href=\"#join\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">Join us<\u002Fa>\n      <\u002Fdiv>\n      <div style=\"display:flex;flex-direction:column;gap:10px\">\n        <span style=\"font-weight:700;color:#fff;margin-bottom:4px\">Follow<\u002Fspan>\n        <a href=\"https://www.instagram.com/leoclubofindore/\" target=\"_blank\" rel=\"noopener\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">Instagram<\u002Fa>\n        <a href=\"https://www.facebook.com/leoclubofindore/\" target=\"_blank\" rel=\"noopener\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">Facebook<\u002Fa>\n        <a href=\"https://twitter.com/ofindore\" target=\"_blank\" rel=\"noopener\" style=\"color:#9b988f;text-decoration:none;font-size:15px;font-weight:500\">Twitter / X<\u002Fa>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n  <div style=\"border-top:1px solid #3a3833;margin-top:36px;padding-top:20px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;color:#6f6c64;font-size:13px;font-weight:500\">\n    <span>© 2026 Leo Club of Indore. All rights reserved.<\u002Fspan>\n    <span style=\"font-family:'Caveat';font-size:18px;color:#FFC73A\">Theme reveal coming soon · 2026–27 ✦<\u002Fspan>\n  <\u002Fdiv>\n<\u002Ffooter>\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nclass Component extends DCLogic {\n  state = { leoTab: 'definition', reel: 0, submitted: false };\n\n  componentDidMount() {\n    // progressive scroll-reveal: enhance only, default-visible\n    this._revealAll = () => {\n      document.querySelectorAll('[data-reveal]').forEach(el => { el.style.opacity = '1'; el.style.transform = 'none'; });\n    };\n    this._t = setTimeout(this._revealAll, 2400);\n    try {\n      const obs = new IntersectionObserver((entries) => {\n        entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'none'; obs.unobserve(e.target); } });\n      }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });\n      requestAnimationFrame(() => {\n        document.querySelectorAll('[data-reveal]').forEach((el) => {\n          el.style.transition = 'opacity .7s ease, transform .75s cubic-bezier(.2,.7,.2,1)';\n          el.style.opacity = '0';\n          el.style.transform = 'translateY(28px)';\n          obs.observe(el);\n        });\n      });\n    } catch (e) { this._revealAll(); }\n  }\n  componentWillUnmount() { clearTimeout(this._t); }\n\n  liftIn = (e) => { e.currentTarget.style.transform = 'translate(-2px,-2px)'; e.currentTarget.style.boxShadow = '6px 6px 0 #FF5A36'; };\n  liftOut = (e) => { e.currentTarget.style.transform = 'none'; e.currentTarget.style.boxShadow = '4px 4px 0 #FF5A36'; };\n\n  renderVals() {\n    const tabsDef = [\n      { key: 'definition', label: 'Definition' },\n      { key: 'history', label: 'History' },\n      { key: 'india', label: 'Leo in India' },\n      { key: 'objectives', label: 'Objectives' },\n      { key: 'pledge', label: 'Pledge' },\n      { key: 'motto', label: 'Motto' },\n      { key: 'flag', label: 'Flag Salute' },\n    ];\n    const active = this.state.leoTab;\n    const tabs = tabsDef.map(t => ({\n      key: t.key,\n      label: t.label,\n      onClick: () => this.setState({ leoTab: t.key }),\n      bg: active === t.key ? '#FF5A36' : 'transparent',\n      fg: active === t.key ? '#fff' : '#FBF9F4',\n      border: active === t.key ? '#FF5A36' : '#5a5751',\n    }));\n    const show = {};\n    tabsDef.forEach(t => { show[t.key] = active === t.key; });\n\n    // EDIT HERE: paste your Instagram reel links (one per line). They render automatically.\n    const reels = [\n      'https://www.instagram.com/reel/DZEikYCoC_J/',\n      'https://www.instagram.com/reel/DYmynNRFHQ1/',\n      'https://www.instagram.com/reel/DXRbDIKkxN4/',\n      'https://www.instagram.com/reel/DUspvbICE8E/',\n      'https://www.instagram.com/reel/DSpvwY8iD2L/',\n      'https://www.instagram.com/reel/DPi05FhkRBg/',\n    ];\n    const reelCards = reels.map(u => {\n      const m = String(u).match(/instagram\\.com\\/(reel|p|tv)\\/([\\w-]+)/i);\n      return { url: u, src: 'https://www.instagram.com/' + (m ? m[1] : 'reel') + '/' + (m ? m[2] : '') + '/embed/' };\n    });\n    const posters = [\n      { tag: '01' }, { tag: '02' }, { tag: '03' }, { tag: '04' }, { tag: '05' }, { tag: '06' },\n    ];\n    // EDIT HERE: event group photos — set name, and later swap the placeholder for your image\n    const gallery = [\n      { img: (window.__resources && window.__resources.moment1) || 'uploads/PHOTO-2025-09-05-23-57-33.jpg', name: 'Event name' },\n      { img: (window.__resources && window.__resources.moment2) || 'uploads/PHOTO-2026-01-11-20-04-04.jpg', name: 'Event name' },\n      { img: (window.__resources && window.__resources.moment3) || 'uploads/PHOTO-2026-02-08-14-36-56.jpg', name: 'Event name' },\n      { img: (window.__resources && window.__resources.moment4) || 'uploads/PHOTO-2026-04-02-00-32-48.jpg', name: 'Event name' },\n      { img: (window.__resources && window.__resources.moment5) || 'uploads/PHOTO-2026-05-05-23-46-25.jpg', name: 'Event name' },\n      { img: (window.__resources && window.__resources.moment6) || 'uploads/PHOTO-2026-05-19-23-06-43.jpg', name: 'Event name' },\n    ];\n    return {\n      tabs, show,\n      reels, reelCards, posters, gallery,\n      nextReel: () => { const el = document.getElementById('reelTrack'); if (el) el.scrollBy({ left: Math.round(el.clientWidth * 0.85), behavior: 'smooth' }); },\n      prevReel: () => { const el = document.getElementById('reelTrack'); if (el) el.scrollBy({ left: -Math.round(el.clientWidth * 0.85), behavior: 'smooth' }); },\n      liftIn: this.liftIn, liftOut: this.liftOut,\n      submitted: this.state.submitted,\n      notSubmitted: !this.state.submitted,\n      onSubmit: (e) => { e.preventDefault(); this.setState({ submitted: true }); },\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"},"entry":"_build_src"}
